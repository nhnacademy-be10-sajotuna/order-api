### 도서별 쿠폰 테스트 전체 프로세스

### 1단계: 재고 생성 (도서 2개)
POST localhost:10366/api/stocks
Content-Type: application/json

{
  "isbn": "9781234567890",
  "quantity": 100
}

### 2단계: 재고 생성 (도서 2개 - 두 번째)
POST localhost:10366/api/stocks
Content-Type: application/json

{
  "isbn": "9781234567891",
  "quantity": 100
}

### 3단계: 일반 쿠폰 생성 (주문 전체에 적용)
POST localhost:10366/api/admin/coupons
Content-Type: application/json

{
  "name": "일반 주문 할인 쿠폰",
  "couponType": "ORDER",
  "policyType": "FIXED",
  "discountAmount": 3000,
  "minOrderAmount": 20000,
  "maxDiscountAmount": 3000,
  "validDays": 30
}

### 4단계: 도서별 쿠폰 생성 (첫 번째 도서용)
POST localhost:10366/api/admin/coupons/book?isbn=9781234567890
Content-Type: application/json

{
  "name": "첫 번째 도서 전용 할인",
  "couponType": "BOOK",
  "policyType": "FIXED",
  "discountAmount": 2000,
  "minOrderAmount": 10000,
  "maxDiscountAmount": 2000,
  "validDays": 30
}

### 5단계: 도서별 쿠폰 생성 (두 번째 도서용)
POST localhost:10366/api/admin/coupons/category?categoryId=2
Content-Type: application/json

{
  "name": "두 번째 도서 전용 할인",
  "couponType": "CATEGORY",
  "policyType": "RATE",
  "discountAmount": 15,
  "minOrderAmount": 15000,
  "maxDiscountAmount": 5000,
  "validDays": 30
}

### 6단계: 사용자에게 일반 쿠폰 발급
POST localhost:10366/api/coupons/users
Content-Type: application/json

{
  "userId": 1,
  "couponId": 1
}

### 7단계: 사용자에게 첫 번째 도서 쿠폰 발급
POST localhost:10366/api/coupons/users
Content-Type: application/json

{
  "userId": 1,
  "couponId": 2
}

### 8단계: 사용자에게 두 번째 도서 쿠폰 발급
POST localhost:10366/api/coupons/users
Content-Type: application/json

{
  "userId": 1,
  "couponId": 3
}

### 9단계: 사용자 쿠폰 목록 확인
GET localhost:10366/api/coupons/users
X-User-Id: 1

### 10단계: 도서별 사용 가능 쿠폰 조회 (첫 번째 도서)
GET localhost:10366/api/coupons/available-coupons/book?isbn=9781234567890&price=15000&categoryIds=
X-User-Id: 1

### 11단계: 도서별 사용 가능 쿠폰 조회 (두 번째 도서)
GET localhost:10366/api/coupons/available-coupons/book?isbn=9781234567891&price=20000&categoryIds=1,2,3
X-User-Id: 1
Content-Type: application/json

### 12단계: 주문별 사용 가능 쿠폰 조회
GET localhost:10366/api/coupons/available-coupons/order?totalPrice=35000
Content-Type: application/json
X-User-Id: 1

### 13단계: 패키지 생성 (테스트용)
POST localhost:10366/api/admin/packages/package
Content-Type: application/json

{
  "packaging": "선물 포장",
  "price": 1000
}

### 14단계: 주문 생성 (도서별 쿠폰 + 주문 쿠폰 + 포인트 사용)
POST localhost:10366/api/orders
Content-Type: application/json
X-User-Id: 1

{
  "ordererName": "홍길동",
  "ordererPhoneNumber": "010-1234-5678",
  "ordererEmail": "hong@example.com",
  "recipientName": "김수령",
  "recipientPhoneNumber": "010-9876-5432",
  "recipientEmail": "kim@example.com",
  "recipientAddress": "서울시 강남구 테헤란로 123",
  "expectedDeliveryDate": "20250730120000",
  "orderCouponId": 1,
  "usedPoint": 1000,
  "items": [
    {
      "orderPackagingId": 1,
      "isbn": "9781234567890",
      "qty": 1,
      "amount": 15000,
      "bookCouponId": 2,
      "packagingRequest": true
    },
    {
      "isbn": "9781234567891",
      "qty": 1,
      "amount": 20000,
      "bookCouponId": 3,
      "packagingRequest": false,
      "categoryIds": [1, 2, 3]
    }
  ]
}